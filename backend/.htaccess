Options -MultiViews
DirectoryIndex disabled

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteRule ^$ http://127.0.0.1:5006/ [P,L]
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule (.*) http://127.0.0.1:5006/$1 [P,L]
</IfModule>
