# ================================================================
# StockVala V2 Backend — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to git.
# ================================================================

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=5006

# ── MySQL Database ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ── JWT Secrets (generate with: openssl rand -hex 64) ───────────
JWT_SECRET=replace_with_64_char_hex_secret
JWT_REFRESH_SECRET=replace_with_different_64_char_hex_secret
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# ── Redis (used for live prices & positions from C# Gateway) ─────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# ── C# MT5 Gateway (Windows VPS running the Gateway service) ────
# This is the primary source for all MT5 operations (trades, balance, prices)
MT5_GATEWAY_URL=http://YOUR_GATEWAY_VPS_IP:8081
MT5_BRIDGE_API_KEY=your_gateway_api_key_here

# MT5 Manager credentials (used by gateway internally — also set on gateway side)
MT5_SERVER=YOUR_MT5_SERVER_IP:443
MT5_MANAGER_LOGIN=your_manager_login
MT5_MANAGER_PASSWORD=your_manager_password

# ── Python MT5 Bridge (optional, fallback for account creation) ──
# Leave blank if you only use the C# Gateway
PYTHON_BRIDGE_URL=
PYTHON_BRIDGE_API_KEY=

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your frontend URLs)
# Use * only for local dev
CORS_ORIGINS=https://app.yourdomain.com,https://yourdomain.com

# ── File Uploads ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# ── Email (SMTP) ─────────────────────────────────────────────────
EMAIL_HOST=mail.yourdomain.com
EMAIL_PORT=465
EMAIL_USER=noreply@yourdomain.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=YourCompanyName

# ── Landing / CRM URLs (for password reset emails) ───────────────
LANDING_URL=https://yourdomain.com
CRM_URL=https://app.yourdomain.com

# ── Gateway Manager Integration ──────────────────────────────────
# When a user follows/unfollows a master, the backend notifies the Gateway Manager
# so it updates its own Redis and the copy engine starts immediately.
# GATEWAY_MANAGER_URL = public URL of manage.stockvala.com (no trailing slash)
# GATEWAY_MANAGER_API_KEY = must match COPY_API_KEY in Gateway Manager .env
GATEWAY_MANAGER_URL=https://manage.stockvala.com
GATEWAY_MANAGER_API_KEY=change-this-to-a-long-random-string

# ── Trading Engines ──────────────────────────────────────────────
# Enable only on dedicated servers — never run two instances with same DB
COPY_ENGINE_ENABLED=true
MAM_ENGINE_ENABLED=false
PAMM_ENGINE_ENABLED=false

# ── Poll Intervals (ms) ──────────────────────────────────────────
COPY_POLL_INTERVAL=3000
MAM_POLL_INTERVAL=5000
PAMM_SNAPSHOT_INTERVAL=60000
