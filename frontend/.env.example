# ================================================================
# StockVala V2 Frontend — Environment Variables
# ================================================================
# IMPORTANT: In production, you do NOT need this file at all.
# domainConfig.js auto-derives all URLs from window.location.hostname:
#
#   hostname = app.yourdomain.com
#   → API_URL  = https://api.yourdomain.com/api
#   → WS_URL   = https://api.yourdomain.com
#   → LANDING  = https://yourdomain.com
#
# This file is only needed for LOCAL DEVELOPMENT.
# ================================================================

# Backend API (Vite proxy forwards /api/* → localhost:5006 in dev)
VITE_API_URL=http://localhost:3001/api

# WebSocket for real-time prices & positions
VITE_WS_URL=http://localhost:3001

# Landing page URL (for back-to-site links)
VITE_LANDING_PAGE_URL=http://localhost:3000

# User CRM URL (for cross-app links)
VITE_USER_CRM_URL=http://localhost:3001
