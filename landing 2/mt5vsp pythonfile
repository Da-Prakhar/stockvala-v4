@app.route("/balance/withdraw", methods=["POST"])
def withdraw():
    """Remove funds from MT5 account based on EQUITY"""
    data = request.json

    if not connect():
        return jsonify(error=MT5Manager.LastError()), 500

    try:
        login = int(data["login"])
        amount = float(data["amount"])
        comment = data.get("comment", "Withdrawal")

        # Get account state to check Equity
        user = manager.UserAccountGet(login)
        if not user:
            disconnect()
            return jsonify(success=False, error="Account not found"), 404

        # Validate against Equity
        if user.Equity < amount:
            disconnect()
            return jsonify(
                success=False,
                error="Insufficient Equity",
                available_equity=user.Equity
            ), 400

        balance_before = user.Balance
        logging.info(f"[Withdraw] Account {login} balance BEFORE: {balance_before}, equity: {user.Equity}")

        # Perform withdrawal (negative amount)
        deal = None
        # Try with enum
        try:
            deal = manager.DealerBalance(login, -amount, MT5Manager.MTDeal.EnDealAction.DEAL_BALANCE, comment)
            logging.info(f"[Withdraw] DealerBalance with enum result: {deal}")
        except Exception as e1:
            logging.info(f"[Withdraw] Enum approach failed: {e1}")

        # Try with int type
        if deal is None or deal is False:
            try:
                deal = manager.DealerBalance(login, -amount, 2, comment)
                logging.info(f"[Withdraw] DealerBalance with int type result: {deal}")
            except Exception as e2:
                logging.info(f"[Withdraw] Int type approach failed: {e2}")

        # Try minimal args
        if deal is None or deal is False:
            try:
                deal = manager.DealerBalance(login, -amount)
                logging.info(f"[Withdraw] DealerBalance minimal result: {deal}")
            except Exception as e3:
                logging.info(f"[Withdraw] Minimal approach failed: {e3}")

        if deal is None or deal is False:
            err_msg = MT5Manager.LastError() or "DealerBalance withdrawal failed"
            logging.error(f"[Withdraw] ALL approaches failed for {login}. Error: {err_msg}")
            disconnect()
            return jsonify(success=False, error=str(err_msg)), 400

        # Get updated stats
        updated_user = manager.UserAccountGet(login)
        new_balance = updated_user.Balance if updated_user else 0
        logging.info(f"[Withdraw] Account {login} balance AFTER: {new_balance}")

        disconnect()
        return jsonify(
            success=True,
            deal_id=deal,
            login=login,
            amount=amount,
            new_balance=new_balance,
            remaining_equity=updated_user.Equity if updated_user else 0,
            comment=comment
        )
    except Exception as e:
        disconnect()
        return jsonify(success=False, error=str(e)), 500

