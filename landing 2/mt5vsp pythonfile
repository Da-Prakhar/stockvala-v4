                            pos_arr = manager.PositionGetByLogins(logins_arr, 1)
                            if pos_arr:
                                positions_found = len(pos_arr)
                        except Exception as e:
                            print(f"  🔍 [POSITION CHECK] Failed: {e}")
                            
                        print(f"  📊 Positions found after DealerSend: {positions_found}")
                        
                        if positions_found == 0:
                            print(f"  ❌ FATAL: MT5 Server REJECTED the order! (Check MT5 Administrator Journal for exact reason)")
                            print(f"  ❌ Falling through to fallback...")
                            # DO NOT RETURN SUCCESS - let it fall through
