@app.route("/debug/try-all-actions/<int:login>", methods=["POST"])
def debug_try_all_actions(login):
    """
    Try DealerSend with EVERY action type to find which one creates real positions.
    Also tries with/without DealerStart, and different symbol formats.
    """
    if not connect():
        return jsonify(error=MT5Manager.LastError()), 500

    data = request.json or {}
    symbol = data.get("symbol", "BTCUSD")
    volume = float(data.get("volume", 0.01))

    bid, ask, digits = _get_live_price(symbol)
    price = ask  # buy

    # Count positions before
    pos_before = 0
    try:
        pdata = manager.PositionGetByLogins([login])
        if pdata:
            pos_before = len(pdata)
    except:
        pass

    results = {"positions_before": pos_before, "price": price, "tests": []}

    # Actions to try: the ones most likely to execute a trade
    actions_to_try = [
        ("TA_REQUEST", 1),
        ("TA_INSTANT", 2),
        ("TA_MARKET", 3),
        ("TA_EXCHANGE", 4),
        ("TA_DEALER_ORD_PENDING", 201),
    ]

    # Also try with symbol suffix
    symbols_to_try = [symbol]
    # Check if server uses .# suffix
    try:
        sym_list = manager.SymbolNext(0)
        if sym_list:
            first_sym = getattr(sym_list, "Symbol", "")
            if ".#" in first_sym or "." in first_sym:
                suffix = first_sym[first_sym.rfind("."):]
                symbols_to_try.append(symbol + suffix)
    except:
        pass
    # Also try common suffixes
    for sfx in [".#", ".raw", ".pro"]:
        candidate = symbol + sfx
        if candidate not in symbols_to_try:
            symbols_to_try.append(candidate)

    results["symbols_to_try"] = symbols_to_try

    for sym in symbols_to_try:
        for action_name, action_val in actions_to_try:
            test = {"symbol": sym, "action": action_name, "action_val": action_val}
            try:
                req = MT5Manager.MTRequest(manager)
                req.Login = login
                req.Symbol = sym
                req.Type = 0  # ORDER_TYPE_BUY
                req.Volume = int(volume * 10000)
                req.PriceOrder = price
                req.Action = action_val
                req.PriceDeviation = 50
                req.TypeFill = 2  # IOC
                req.TypeTime = 0  # GTC
                req.Comment = f"Test_{action_name}"

                send_result = manager.DealerSend(req)

                # Read back the result fields from the request
                test["send_result"] = str(send_result) if send_result is not None else "None"
                test["ResultRetcode"] = getattr(req, "ResultRetcode", "N/A")
                test["ResultDeal"] = getattr(req, "ResultDeal", "N/A")
                test["ResultOrder"] = getattr(req, "ResultOrder", "N/A")
                test["ResultPrice"] = getattr(req, "ResultPrice", "N/A")
                test["ResultVolume"] = getattr(req, "ResultVolume", "N/A")
                test["ResultComment"] = getattr(req, "ResultComment", "N/A")
                test["last_error"] = MT5Manager.LastError()

            except Exception as e:
                test["error"] = str(e)

            results["tests"].append(test)
            print(f"  [{action_name}] sym={sym} => result={test.get('send_result')}, retcode={test.get('ResultRetcode')}, deal={test.get('ResultDeal')}")

    # Now try with DealerStart flow
    dealer_start_test = {"method": "DealerStart+DealerSend"}
    try:
        # Check if DealerStart exists
        if hasattr(manager, "DealerStart"):
            ds = manager.DealerStart()
            dealer_start_test["dealer_start_result"] = str(ds)

            req = MT5Manager.MTRequest(manager)
            req.Login = login
            req.Symbol = symbol
            req.Type = 0
            req.Volume = int(volume * 10000)
            req.PriceOrder = price
            req.Action = 3  # TA_MARKET
            req.PriceDeviation = 50
            req.TypeFill = 2
            req.Comment = "Test_DealerStart"

            send_result = manager.DealerSend(req)
            dealer_start_test["send_result"] = str(send_result) if send_result is not None else "None"
            dealer_start_test["ResultRetcode"] = getattr(req, "ResultRetcode", "N/A")
            dealer_start_test["ResultDeal"] = getattr(req, "ResultDeal", "N/A")
            dealer_start_test["ResultOrder"] = getattr(req, "ResultOrder", "N/A")

            if hasattr(manager, "DealerStop"):
                manager.DealerStop()
        else:
            dealer_start_test["error"] = "DealerStart not available"
    except Exception as e:
        dealer_start_test["error"] = str(e)

    results["dealer_start_test"] = dealer_start_test

    # Count positions after all tests
    import time
    time.sleep(2)
    pos_after = 0
    pos_list = []
    try:
        pdata = manager.PositionGetByLogins([login])
        if pdata:
            pos_after = len(pdata)
            for p in pdata:
