                logging.info(f"[Deposit] Approach 2 result: {deal}")
            except Exception as e2:
                last_err = str(e2)
                logging.info(f"[Deposit] Approach 2 failed: {e2}")

        # Approach 3: just (login, amount) - maybe it only takes 2 args
        if deal is None or deal is False:
            try:
                logging.info(f"[Deposit] Trying: DealerBalance({login}, {amount})")
                deal = manager.DealerBalance(login, amount)
                logging.info(f"[Deposit] Approach 3 result: {deal}")
            except Exception as e3:
                last_err = str(e3)
                logging.info(f"[Deposit] Approach 3 failed: {e3}")

        # Approach 4: (login, amount, comment) - 3 args
        if deal is None or deal is False:
            try:
                logging.info(f"[Deposit] Trying: DealerBalance({login}, {amount}, '{comment}')")
                deal = manager.DealerBalance(login, amount, comment)
                logging.info(f"[Deposit] Approach 4 result: {deal}")
            except Exception as e4:
                last_err = str(e4)
                logging.info(f"[Deposit] Approach 4 failed: {e4}")

        # Approach 5: Try DealerBalanceRaw or other variants
        if deal is None or deal is False:
            balance_methods = [attr for attr in dir(manager) if 'balance' in attr.lower() or 'dealer' in attr.lower()]
            logging.info(f"[Deposit] Available balance/dealer methods: {balance_methods}")

        if deal is None or deal is False:
