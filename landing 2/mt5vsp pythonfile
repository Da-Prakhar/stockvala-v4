def _detect_market(symbol):
    """Detect market category from symbol name"""
    s = (symbol or "").upper().replace(".#", "").replace(".", "")
    # MCX commodity base names
    MCX_NAMES = ("GOLD", "GOLDM", "SILVER", "SILVERM", "CRUDEOIL", "NATURALGAS",
                 "COPPER", "ZINC", "ALUMINIUM", "LEAD", "NICKEL", "COTTON", "COTTONCANDY")
    # NSE stock/index base names
    NSE_NAMES = ("NIFTY", "BANKNIFTY", "FINNIFTY", "NIFTYIT", "RELIANCE", "TCS",
                 "HDFCBANK", "INFY", "ICICIBANK", "SBIN", "BHARTIARTL", "ITC",
                 "TATAMOTORS", "WIPRO", "ADANIENT", "TATASTEEL", "SENSEX",
                 "MIDCPNIFTY", "NIFTYBANK")
    ALL_MCX_NSE = MCX_NAMES + NSE_NAMES

    # Exact match
    if s in ALL_MCX_NSE:
        return "mcx"
    # Partial match: symbol might already include month suffix like BANKNIFTYMAY, GOLDJUN26
    for base in ALL_MCX_NSE:
        if s.startswith(base) and len(s) > len(base):
            return "mcx"
    # COMEX
    if s.startswith("XAU") or s.startswith("XAG") or s.startswith("XPT") or s.startswith("XPD"):
        return "comex"
    # Default = forex (forex, crypto, indices)
    return "forex"

def _switch_terminal_to_market(market):
    """Switch the MT5 terminal login to the account for the given market.
    Returns True if terminal is ready for that market.
    Thread-safe: acquires _terminal_lock."""
    global _current_terminal_market, _terminal_initialized

    if not MT5_TERMINAL_AVAILABLE:
        return False

    # Already on the right market (check outside lock for fast path)
    if _terminal_initialized and _current_terminal_market == market:
        return True

    with _terminal_lock:
        # Re-check inside lock (another thread may have switched already)
        if _terminal_initialized and _current_terminal_market == market:
            return True

        # Get the credentials for this market
        acct = TERMINAL_ACCOUNTS.get(market, {})
        login = acct.get("login", 0)
        password = acct.get("password", "")
        server = acct.get("server", "176.126.66.38:443")

        # Fall back to default if market-specific account not configured
        if not login or login == 0:
            login = MT5_TERMINAL_CONFIG.get("login", 0)
            password = MT5_TERMINAL_CONFIG.get("password", "")
            server = MT5_TERMINAL_CONFIG.get("server", "176.126.66.38:443")

        if not login or login == 0:
            print(f"[Terminal] No trading account configured for market '{market}' — skipping terminal")
            return False

        print(f"[Terminal] Switching to market '{market}' — login {login} on {server}")

        # If terminal not initialized at all, do full init
        if not _terminal_initialized:
            if init_terminal(login=login, password=password, server=server):
                _current_terminal_market = market
                return True
            return False

        # Terminal is initialized but on wrong market — try re-login with multiple server name formats
        # The MetaTrader5 Python package sometimes needs a different server format than the IP
        server_variants = ["MajestyFX-Trade", server, "176.126.66.38:443", "176.126.66.38", "MajestyFx-Server", "PrimewaveFX-Trade", ""]
        seen = set()
        for srv in server_variants:
            if srv in seen:
                continue
            seen.add(srv)
            try:
                if srv:
                    authorized = mt5.login(int(login), password=password, server=srv)
                else:
                    authorized = mt5.login(int(login), password=password)
                if authorized:
                    info = mt5.account_info()
                    actual_login = info.login if info else login
                    print(f"  ✅ Terminal switched to market '{market}': account={actual_login} (server='{srv}')")
                    _current_terminal_market = market
                    return True
                else:
                    err = mt5.last_error()
                    print(f"  ❌ Terminal login failed on '{srv}': {err}")
            except Exception as e:
                print(f"  ❌ Terminal login exception on '{srv}': {e}")

        print(f"  ❌ All server variants failed for market '{market}', login {login}")
        return False

def init_terminal(login=None, password=None, server=None):
    """Initialize the MT5 terminal for trade execution"""
    global _terminal_initialized
    if not MT5_TERMINAL_AVAILABLE:
        return False
    if _terminal_initialized:
        return True

    # The terminal executable path
    MT5_TERMINAL_PATH = r"C:\Program Files\MetaTrader 5\terminal64.exe"

    # Try multiple initialization approaches
    initialized = False
    init_attempts = []

    # Attempt 1: Full path with login/password/server in initialize() call
    use_login = login or MT5_TERMINAL_CONFIG.get("login")
    use_password = password or MT5_TERMINAL_CONFIG.get("password") or os.environ.get("MT5_TERMINAL_PASSWORD", "")
    use_server = server or MT5_TERMINAL_CONFIG.get("server", "")

    try:
        result = mt5.initialize(
            path=MT5_TERMINAL_PATH,
            login=int(use_login) if use_login else None,
            password=use_password if use_password else None,
            server=use_server if use_server else None,
            timeout=10000
        )
        if result:
            initialized = True
            init_attempts.append(f"Full init with path+credentials: SUCCESS")
        else:
            err = mt5.last_error()
            init_attempts.append(f"Full init with path+credentials: FAILED {err}")
    except Exception as e:
        init_attempts.append(f"Full init with path+credentials: EXCEPTION {e}")

    # Attempt 2: Just path, no credentials
    if not initialized:
        try:
            result = mt5.initialize(path=MT5_TERMINAL_PATH)
            if result:
                initialized = True
                init_attempts.append(f"Path only: SUCCESS")
            else:
                err = mt5.last_error()
                init_attempts.append(f"Path only: FAILED {err}")
        except Exception as e:
            init_attempts.append(f"Path only: EXCEPTION {e}")

    # Attempt 3: No path (auto-detect / connect to running instance)
    if not initialized:
        try:
            result = mt5.initialize()
            if result:
                initialized = True
                init_attempts.append(f"Auto-detect: SUCCESS")
            else:
                err = mt5.last_error()
                init_attempts.append(f"Auto-detect: FAILED {err}")
        except Exception as e:
            init_attempts.append(f"Auto-detect: EXCEPTION {e}")

    # Attempt 4: Portable mode
    if not initialized:
        try:
            result = mt5.initialize(path=MT5_TERMINAL_PATH, portable=True)
            if result:
                initialized = True
                init_attempts.append(f"Portable mode: SUCCESS")
            else:
                err = mt5.last_error()
                init_attempts.append(f"Portable mode: FAILED {err}")
        except Exception as e:
            init_attempts.append(f"Portable mode: EXCEPTION {e}")

    for attempt in init_attempts:
        print(f"  [Terminal Init] {attempt}")

    if not initialized:
        print(f"❌ MT5 Terminal initialize() failed - all attempts exhausted")
        return False

    print(f"✅ MT5 Terminal initialized (connected to terminal process)")

    # Now login with a trading account
    use_login = login or MT5_TERMINAL_CONFIG.get("login")
    use_password = password or MT5_TERMINAL_CONFIG.get("password") or os.environ.get("MT5_TERMINAL_PASSWORD", "")
    use_server = server or MT5_TERMINAL_CONFIG.get("server", "")

    # Check if we're logged in after initialize
    info = mt5.account_info()
    if info and info.login > 0:
        print(f"  ✅ Terminal logged in: account={info.login}, balance={info.balance}, server={info.server}")
        _terminal_initialized = True
        return True

    # If initialize succeeded but not logged in, try explicit login
    if use_login and use_password:
        server_names = ["MajestyFX-Trade", use_server, "176.126.66.38:443", "176.126.66.38", "MajestyFx-Server", "PrimewaveFX-Trade", ""]
        seen = set()
        for srv in server_names:
            if srv in seen:
                continue
            seen.add(srv)
            label = srv if srv else "(default)"
            print(f"  Trying login {use_login} on server '{label}'...")
            try:
                authorized = mt5.login(int(use_login), password=use_password, server=srv) if srv else mt5.login(int(use_login), password=use_password)
                if authorized:
                    info = mt5.account_info()
                    if info:
                        print(f"  ✅ Terminal logged in: account={info.login}, balance={info.balance}, server={info.server}")
                    else:
                        print(f"  ✅ Terminal logged in as {use_login}")
                    _terminal_initialized = True
                    return True
                else:
                    err = mt5.last_error()
                    print(f"  ❌ Login failed on '{label}': {err}")
            except Exception as e:
                print(f"  ❌ Login exception on '{label}': {e}")

    # Even if login failed, mark initialized if terminal is connected
    term_info = mt5.terminal_info()
    if term_info and term_info.connected:
        print(f"  ⚠️ Terminal connected but not logged in. Log in manually in MT5 Terminal.")
        _terminal_initialized = True
        return True

    print(f"  ❌ Terminal not connected or login failed")
    return False

def ensure_terminal(symbol=None):
    """Ensure terminal is initialized and logged into the right market for the given symbol.
    If symbol is provided, switches to the matching market account."""
    global _terminal_initialized
    if symbol:
        market = _detect_market(symbol)
        return _switch_terminal_to_market(market)
    if _terminal_initialized:
        return True
    return init_terminal()
