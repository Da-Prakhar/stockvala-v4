# ===== CRITICAL: DealerSend + DealerGet + DealerAnswer flow =====
# In MT5, DealerSend queues a request. The dealer must then:
#   1. DealerGet() — retrieve the pending request
#   2. DealerAnswer() — confirm execution
# Without this confirmation step, requests sit in queue forever.

@app.route("/debug/dealer-full-flow/<int:login>", methods=["POST"])
def debug_dealer_full_flow(login):
    """
    FULL dealer flow: DealerStart → DealerSend → DealerGet → DealerAnswer
    This is the correct MT5 Manager API pattern for trade execution.
    POST body: { "symbol": "BTCUSD", "action": "buy", "volume": 0.01 }
    """
    if not connect():
        return jsonify(error=MT5Manager.LastError()), 500

    data = request.json or {}
    symbol = data.get("symbol", "BTCUSD")
    action_str = data.get("action", "buy").lower()
    volume = float(data.get("volume", 0.01))
    sl = float(data.get("sl", 0))
    tp = float(data.get("tp", 0))

    bid, ask, digits = _get_live_price(symbol)
    price = ask if action_str == "buy" else bid
    trade_type = 0 if action_str == "buy" else 1
    volume_units = int(volume * 10000)

    results = {
        "login": login, "symbol": symbol, "action": action_str,
        "volume": volume, "price": price, "bid": bid, "ask": ask,
        "steps": []
    }

    # Count positions BEFORE
    pos_before = 0
    try:
        pdata = manager.PositionGetByLogins([login])
        pos_before = len(pdata) if pdata else 0
    except:
        pass
    results["positions_before"] = pos_before

    # ── STEP 1: Discover ALL dealer methods ──
    dealer_methods = []
    for m in sorted(dir(manager)):
        if "dealer" in m.lower() or "deal" in m.lower():
            try:
                obj = getattr(manager, m)
                dealer_methods.append({"name": m, "callable": callable(obj)})
            except:
                dealer_methods.append({"name": m, "error": True})
    results["all_dealer_methods"] = dealer_methods

    # Also find ANY order/trade/position creation methods
    creation_methods = []
    for m in sorted(dir(manager)):
        ml = m.lower()
        if any(k in ml for k in ["order", "trade", "position", "send", "execute", "confirm", "answer"]):
            if not m.startswith("_"):
                try:
                    obj = getattr(manager, m)
                    creation_methods.append({"name": m, "callable": callable(obj)})
                except:
                    creation_methods.append({"name": m, "error": True})
    results["all_creation_methods"] = creation_methods

    # ── STEP 2: DealerStart ──
    try:
        ds_result = manager.DealerStart()
        results["steps"].append({"step": "DealerStart", "result": str(ds_result), "success": bool(ds_result)})
        print(f"[DEALER] DealerStart: {ds_result}")
    except Exception as e:
        results["steps"].append({"step": "DealerStart", "error": str(e)})

    # ── STEP 3: DealerSend ──
    send_result = None
    try:
        req = MT5Manager.MTRequest(manager)
        req.Login = login
        req.Symbol = symbol
        req.Type = trade_type
        req.Volume = volume_units
        req.PriceOrder = price
        req.Action = 2  # TA_INSTANT

        for attr, val in [("Deviation", 50), ("Comment", "CRM_Dealer_Flow"),
                          ("TypeFill", 2), ("TypeTime", 0)]:
            try: setattr(req, attr, val)
            except: pass

        if sl > 0:
            try: req.PriceSL = float(sl)
            except: pass
        if tp > 0:
            try: req.PriceTP = float(tp)
            except: pass

        send_result = manager.DealerSend(req)
        sr_str = str(send_result)
        results["steps"].append({"step": "DealerSend", "result": sr_str, "type": type(send_result).__name__})
        print(f"[DEALER] DealerSend: {sr_str}")
    except Exception as e:
        results["steps"].append({"step": "DealerSend", "error": str(e)})

    # ── STEP 4: Try DealerGet (retrieve pending request for confirmation) ──
    dealer_get_result = None
    for method_name in ["DealerGet", "DealerGetRequest", "DealerReceive", "DealerPoll"]:
        fn = getattr(manager, method_name, None)
        if fn and callable(fn):
            try:
                dealer_get_result = fn()
                results["steps"].append({
                    "step": method_name, "result": str(dealer_get_result),
                    "type": type(dealer_get_result).__name__ if dealer_get_result else "None"
                })
                print(f"[DEALER] {method_name}: {dealer_get_result}")

                # If we got an object, dump all its attributes
                if dealer_get_result is not None:
                    get_dump = {}
                    for a in dir(dealer_get_result):
                        if not a.startswith("_"):
                            try:
                                v = getattr(dealer_get_result, a)
                                if not callable(v):
                                    get_dump[a] = str(v)
                            except:
                                pass
                    results[f"{method_name}_dump"] = get_dump
                break
            except Exception as e:
                results["steps"].append({"step": method_name, "error": str(e)})
                import traceback
                results[f"{method_name}_traceback"] = traceback.format_exc()

    # ── STEP 5: Try DealerAnswer / DealerConfirm (confirm execution) ──
    for answer_method in ["DealerAnswer", "DealerConfirm", "DealerAccept", "DealerExecute"]:
        fn = getattr(manager, answer_method, None)
        if fn and callable(fn):
            # Try multiple calling patterns
            patterns = []

            # Pattern A: DealerAnswer(confirm_obj) — pass back the request/confirmation object
            if dealer_get_result is not None:
                try:
                    ans = fn(dealer_get_result)
                    patterns.append({"pattern": f"{answer_method}(get_result)", "result": str(ans)})
                    print(f"[DEALER] {answer_method}(get_result): {ans}")
                except Exception as e:
                    patterns.append({"pattern": f"{answer_method}(get_result)", "error": str(e)})

            # Pattern B: DealerAnswer(MTConfirmation) with RetCode=10009 (DONE)
            for conf_cls_name in ["MTConfirmation", "MTConConfirmation", "MTConfirm"]:
                conf_cls = getattr(MT5Manager, conf_cls_name, None)
                if conf_cls:
                    try:
                        conf_obj = conf_cls(manager)
                        # Set confirmation fields
                        for attr, val in [
                            ("RetCode", 10009),  # TRADE_RETCODE_DONE
                            ("Retcode", 10009),
                            ("Login", login),
                            ("Volume", volume_units),
                            ("Price", price),
                            ("Bid", bid), ("Ask", ask),
                            ("ID", send_result if isinstance(send_result, int) else 0),
                        ]:
                            try: setattr(conf_obj, attr, val)
                            except: pass

                        ans = fn(conf_obj)
                        patterns.append({"pattern": f"{answer_method}({conf_cls_name})", "result": str(ans)})
                        print(f"[DEALER] {answer_method}({conf_cls_name}): {ans}")
                    except Exception as e:
                        patterns.append({"pattern": f"{answer_method}({conf_cls_name})", "error": str(e)})

            # Pattern C: DealerAnswer(req) — pass back the original request
            try:
                req2 = MT5Manager.MTRequest(manager)
                req2.Login = login
                req2.Symbol = symbol
                req2.Type = trade_type
                req2.Volume = volume_units
                req2.PriceOrder = price
                req2.Action = 2
                try: req2.RetCode = 10009
                except: pass
                try: req2.Retcode = 10009
                except: pass

                ans = fn(req2)
                patterns.append({"pattern": f"{answer_method}(MTRequest_with_retcode)", "result": str(ans)})
                print(f"[DEALER] {answer_method}(req_with_retcode): {ans}")
            except Exception as e:
                patterns.append({"pattern": f"{answer_method}(MTRequest_with_retcode)", "error": str(e)})

            # Pattern D: DealerAnswer(int) — pass the order ID
            if send_result is not None:
                try:
                    order_id = int(send_result) if not isinstance(send_result, int) else send_result
                    ans = fn(order_id)
                    patterns.append({"pattern": f"{answer_method}(order_id={order_id})", "result": str(ans)})
                except Exception as e:
                    patterns.append({"pattern": f"{answer_method}(order_id)", "error": str(e)})

            results["steps"].append({"step": answer_method, "patterns": patterns})

    # ── STEP 6: Try OrderAdd/OrderSend directly ──
    for order_method in ["OrderAdd", "OrderSend", "OrderCreate", "TradeTransaction"]:
        fn = getattr(manager, order_method, None)
        if fn and callable(fn):
            # Try with MTOrder object
            for order_cls in ["MTOrder", "MTConOrder", "Order"]:
                cls = getattr(MT5Manager, order_cls, None)
                if cls:
                    try:
                        order_obj = cls(manager)
                        for attr, val in [
                            ("Login", login), ("Symbol", symbol),
                            ("Type", trade_type), ("Volume", volume_units),
                            ("PriceOrder", price), ("Price", price),
                            ("Action", 2), ("State", 0),
                            ("Comment", "CRM_OrderAdd"),
                        ]:
                            try: setattr(order_obj, attr, val)
                            except: pass

                        oa_result = fn(order_obj)
                        results["steps"].append({
                            "step": f"{order_method}({order_cls})",
                            "result": str(oa_result),
                        })
                        print(f"[DEALER] {order_method}({order_cls}): {oa_result}")
                    except Exception as e:
                        results["steps"].append({
                            "step": f"{order_method}({order_cls})",
                            "error": str(e),
                        })

            # Also try with MTRequest
            try:
                req3 = MT5Manager.MTRequest(manager)
                req3.Login = login
                req3.Symbol = symbol
                req3.Type = trade_type
                req3.Volume = volume_units
                req3.PriceOrder = price
                req3.Action = 2

                oa_result = fn(req3)
                results["steps"].append({
                    "step": f"{order_method}(MTRequest)",
                    "result": str(oa_result),
                })
            except Exception as e:
                results["steps"].append({
                    "step": f"{order_method}(MTRequest)",
                    "error": str(e),
                })

    # ── STEP 7: Try PositionModify / PositionAdd directly ──
    for pos_method in ["PositionAdd", "PositionCreate", "PositionModify"]:
        fn = getattr(manager, pos_method, None)
        if fn and callable(fn):
            for pos_cls in ["MTPosition", "MTConPosition", "Position"]:
                cls = getattr(MT5Manager, pos_cls, None)
                if cls:
                    try:
                        pos_obj = cls(manager)
                        for attr, val in [
                            ("Login", login), ("Symbol", symbol),
                            ("Action", trade_type), ("Volume", volume_units),
                            ("PriceOpen", price), ("PriceCurrent", price),
                            ("PriceSL", sl if sl > 0 else 0),
                            ("PriceTP", tp if tp > 0 else 0),
                            ("Comment", "CRM_PosAdd"),
                            ("Reason", 0),
                        ]:
                            try: setattr(pos_obj, attr, val)
                            except: pass

                        pa_result = fn(pos_obj)
                        results["steps"].append({
                            "step": f"{pos_method}({pos_cls})",
                            "result": str(pa_result),
                        })
                        print(f"[DEALER] {pos_method}({pos_cls}): {pa_result}")
                    except Exception as e:
                        results["steps"].append({
                            "step": f"{pos_method}({pos_cls})",
                            "error": str(e),
                        })

    # ── STEP 8: DealerStop ──
    try:
        manager.DealerStop()
        results["steps"].append({"step": "DealerStop", "result": "OK"})
    except:
        pass

    # ── STEP 9: Check positions AFTER ──
    time.sleep(2)
    pos_after = 0
    pos_detail = []
    try:
        pdata = manager.PositionGetByLogins([login])
        pos_after = len(pdata) if pdata else 0
        if pdata:
            for p in pdata[:5]:
                pd = {}
                for a in dir(p):
                    if not a.startswith("_"):
                        try:
                            v = getattr(p, a)
                            if not callable(v):
                                pd[a] = str(v)
                        except:
                            pass
                pos_detail.append(pd)
    except:
        pass
    results["positions_after"] = pos_after
    results["positions_detail"] = pos_detail
    results["new_positions"] = pos_after - pos_before

    # ── STEP 10: Check ALL MT5Manager classes for anything we missed ──
    all_classes = {}
    for name in sorted(dir(MT5Manager)):
        if name.startswith("_"):
            continue
        obj = getattr(MT5Manager, name)
        if isinstance(obj, type):
            all_classes[name] = [a for a in dir(obj) if not a.startswith("_")][:30]
    results["all_mt5_classes"] = all_classes

    return jsonify(success=True, **results)


# ===== ULTIMATE: Try EVERY callable method on manager with trade objects =====
@app.route("/debug/brute-force-trade/<int:login>", methods=["POST"])
def debug_brute_force_trade(login):
    """
    Brute-force: try EVERY callable method on the manager object that might create
    a position. Tests OrderAdd, TradeTransaction, DealPerform, etc. with every
    possible object type.
    """
    if not connect():
        return jsonify(error=MT5Manager.LastError()), 500

    data = request.json or {}
    symbol = data.get("symbol", "BTCUSD")
    action_str = data.get("action", "buy").lower()
    volume = float(data.get("volume", 0.01))

    bid, ask, digits = _get_live_price(symbol)
    price = ask if action_str == "buy" else bid
    trade_type = 0 if action_str == "buy" else 1
    volume_units = int(volume * 10000)

    results = {"tests": [], "login": login, "symbol": symbol, "price": price}

    # Positions before
    pos_before = 0
    try:
        pdata = manager.PositionGetByLogins([login])
        pos_before = len(pdata) if pdata else 0
    except:
        pass
    results["positions_before"] = pos_before

    # Get ALL callable methods on manager
    all_methods = []
    for m in sorted(dir(manager)):
        if m.startswith("_"):
            continue
        try:
            obj = getattr(manager, m)
            if callable(obj):
                all_methods.append(m)
        except:
            pass
    results["all_callable_methods"] = all_methods

    # Filter to potentially trade-related ones
    trade_keywords = ["order", "trade", "deal", "send", "execute", "position",
                      "transaction", "confirm", "answer", "perform", "add", "create"]
    trade_methods = [m for m in all_methods
                     if any(k in m.lower() for k in trade_keywords)
                     and m not in ["DealRequestByLogins", "DealRequestByTickets",
                                   "DealRequestByGroup", "PositionGetByLogins",
                                   "PositionGetByGroup", "PositionGet",
                                   "OrderGetByLogins", "OrderGet", "OrderGetOpen"]]
    results["trade_methods_to_try"] = trade_methods

    # Get ALL instantiatable classes
    mt5_classes = {}
    for name in sorted(dir(MT5Manager)):
        obj = getattr(MT5Manager, name, None)
        if isinstance(obj, type):
            mt5_classes[name] = obj
    results["available_classes"] = list(mt5_classes.keys())

    # Try each trade method with each relevant class
    for method_name in trade_methods:
        fn = getattr(manager, method_name)

        # Try with no args
        try:
            r = fn()
            results["tests"].append({
                "method": f"{method_name}()",
                "result": str(r)[:200],
                "type": type(r).__name__ if r is not None else "None"
            })
        except Exception as e:
            results["tests"].append({
                "method": f"{method_name}()",
                "error": str(e)[:200]
            })

        # Try with each class object
        for cls_name, cls in mt5_classes.items():
            if any(k in cls_name.lower() for k in ["deal", "order", "request", "position", "trade", "confirm"]):
                try:
                    obj = cls(manager)
                except:
                    try:
                        obj = cls()
                    except:
                        continue

                # Set common trade fields
                for attr, val in [
                    ("Login", login), ("Symbol", symbol),
                    ("Type", trade_type), ("Action", trade_type),
                    ("Volume", volume_units), ("VolumeExt", volume_units),
                    ("Price", price), ("PriceOrder", price),
                    ("PriceOpen", price), ("PriceCurrent", price),
                    ("PricePosition", price),
                    ("Bid", bid), ("Ask", ask), ("MarketBid", bid), ("MarketAsk", ask),
                    ("Digits", digits), ("Comment", "CRM_BruteForce"),
                    ("Dealer", MT5_CONFIG["manager"]),
                    ("Entry", 0), ("Reason", 0),
                    ("ContractSize", 1.0), ("RateProfit", 1.0), ("RateMargin", 1.0),
                    ("Time", int(time.time())), ("TimeMsc", int(time.time() * 1000)),
                    ("Deviation", 50), ("TypeFill", 2), ("TypeTime", 0),
                    ("RetCode", 10009), ("Retcode", 10009),
                ]:
                    try: setattr(obj, attr, val)
                    except: pass

                try:
                    r = fn(obj)
                    results["tests"].append({
                        "method": f"{method_name}({cls_name})",
                        "result": str(r)[:200],
                        "type": type(r).__name__ if r is not None else "None",
                    })
                except Exception as e:
                    err_str = str(e)[:200]
                    # Skip boring errors
                    if "argument" not in err_str.lower() and "type" not in err_str.lower():
                        results["tests"].append({
                            "method": f"{method_name}({cls_name})",
                            "error": err_str,
                        })

    # Positions after
    time.sleep(2)
    pos_after = 0
    try:
        pdata = manager.PositionGetByLogins([login])
        pos_after = len(pdata) if pdata else 0
    except:
        pass
    results["positions_after"] = pos_after
    results["new_positions"] = pos_after - pos_before

    return jsonify(success=True, **results)


