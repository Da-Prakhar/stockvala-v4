    volume = float(data.get("volume", 0.01))

    if not connect():
        return jsonify(error=MT5Manager.LastError()), 500

    # Get positions before
    pos_before = []
    try:
        pdata = manager.PositionGetByLogins([login])
        if pdata:
            for p in pdata:
                pos_before.append({
                    "ticket": getattr(p, "Position", 0),
                    "symbol": getattr(p, "Symbol", ""),
                    "volume": getattr(p, "Volume", 0),
                })
    except:
        pass

    # Execute the trade via the main endpoint logic
    import io
