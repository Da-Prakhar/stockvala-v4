}


def _fetch_price_binance(symbol):
    """Fetch bid/ask from Binance public API (crypto pairs)"""
    binance_sym = BINANCE_MAP.get(symbol)
    if not binance_sym:
        return 0, 0
    try:
        resp = http_requests.get(
            f"https://api.binance.com/api/v3/ticker/bookTicker?symbol={binance_sym}",
            timeout=3
        )
        if resp.status_code == 200:
            data = resp.json()
            bid = float(data.get("bidPrice", 0))
            ask = float(data.get("askPrice", 0))
            return bid, ask
    except Exception as e:
        print(f"Binance API error for {symbol}: {e}")
    return 0, 0


def _fetch_price_forex(symbol):
    """Fetch forex prices using free public APIs"""
    # Try ExchangeRate API (no key needed for basic)
    if len(symbol) == 6:
        base = symbol[:3]
        quote = symbol[3:]
        try:
            resp = http_requests.get(
                f"https://open.er-api.com/v6/latest/{base}",
                timeout=4
            )
            if resp.status_code == 200:
                data = resp.json()
                rate = data.get("rates", {}).get(quote, 0)
                if rate > 0:
                    # Approximate bid/ask with tiny spread
                    digits = SYMBOL_DIGITS.get(symbol, 5)
                    spread_pips = 1 / (10 ** digits)  # 1 pip spread
                    bid = rate - spread_pips / 2
                    ask = rate + spread_pips / 2
                    return bid, ask
        except Exception as e:
            print(f"Forex API error for {symbol}: {e}")
    return 0, 0


