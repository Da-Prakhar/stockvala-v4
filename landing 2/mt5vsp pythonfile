                )
            else:
                print(f"  EA not responding (not running?): {ea_result.get('error', 'unknown')}")

        # ── PRIORITY 1: DealerSend via Manager API (with correct prices) ──
        if connect():
            print(f"  [P1] Trying DealerSend with market price={market_price}")

            # Count positions BEFORE to verify if position was created
            pos_before = 0
            try:
                pdata = manager.PositionGetByLogins([login])
