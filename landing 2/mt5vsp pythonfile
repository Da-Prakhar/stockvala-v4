_chart_cache = {}  # {symbol_timeframe: {"data": [...], "_ts": timestamp}}

@app.route("/chart/<symbol>", methods=["GET"])
def get_chart_data(symbol):
    """
    Get OHLC candle data for charting.
    Query params:
      timeframe: M1, M5, M15, M30, H1, H4, D1 (default M15)
      count: number of bars (default 200, max 1000)

    Uses MT5 Terminal API (copy_rates) if available, else builds from tick data.
    """
    timeframe_str = request.args.get("timeframe", "M15").upper()
    count = min(int(request.args.get("count", 200)), 1000)

    # Map timeframe string to MT5 constant
    tf_map = {
        "M1": 1, "M5": 5, "M15": 15, "M30": 30,
        "H1": 60, "H4": 240, "D1": 1440, "W1": 10080, "MN1": 43200,
    }
    tf_minutes = tf_map.get(timeframe_str, 15)

    # Check cache — longer TTL for MCX to avoid terminal switching storms
    # Forex: 10s, MCX/Comex: 30s (reduces terminal switches for multi-market)
    chart_market = _detect_market(symbol)
    cache_ttl = 30 if chart_market in ("mcx", "comex") else 10
    cache_key = f"{symbol}_{timeframe_str}_{count}"
    cached = _chart_cache.get(cache_key)
    if cached and (time.time() - cached.get("_ts", 0)) < cache_ttl:
        return jsonify(success=True, symbol=symbol, timeframe=timeframe_str, candles=cached["data"], count=len(cached["data"]))

    norm_symbol = _normalize_symbol(symbol)
    candles = []

    # Try MT5 Terminal API first (most accurate) — switch to right market
    # Wrapped in _terminal_lock for thread safety
    if MT5_TERMINAL_AVAILABLE:
        with _terminal_lock:
            if ensure_terminal(symbol=symbol):
                try:
                    import datetime
                    tf_const_map = {
                        1: mt5.TIMEFRAME_M1, 5: mt5.TIMEFRAME_M5, 15: mt5.TIMEFRAME_M15,
                        30: mt5.TIMEFRAME_M30, 60: mt5.TIMEFRAME_H1, 240: mt5.TIMEFRAME_H4,
                        1440: mt5.TIMEFRAME_D1, 10080: mt5.TIMEFRAME_W1, 43200: mt5.TIMEFRAME_MN1,
                    }
                    tf_const = tf_const_map.get(tf_minutes, mt5.TIMEFRAME_M15)

                    base_sym = symbol.replace(".#", "") if ".#" in symbol else symbol
                    sym_variants = list(dict.fromkeys([norm_symbol, base_sym, base_sym + ".#"]))

                    for sym_try in sym_variants:
                        try:
                            mt5.symbol_select(sym_try, True)
                            rates = mt5.copy_rates_from_pos(sym_try, tf_const, 0, count)
                            if rates is not None and len(rates) > 0:
                                for bar in rates:
                                    candles.append({
                                        "time": int(bar[0]),
                                        "open": float(bar[1]),
                                        "high": float(bar[2]),
                                        "low": float(bar[3]),
                                        "close": float(bar[4]),
                                        "volume": int(bar[5]),
                                    })
                                print(f"[Chart] {symbol} (as '{sym_try}'): {len(candles)} bars from MT5 Terminal ({timeframe_str})")
                                break
                        except:
                            pass
                except Exception as e:
                    print(f"[Chart] Terminal copy_rates failed for {symbol}: {e}")

    # Fallback: Use public API for price data
    if not candles:
        try:
            base_symbol = symbol.replace(".#", "").replace(".", "")
            # Try to get data from a public API
            interval_map = {
                "M1": "1m", "M5": "5m", "M15": "15m", "M30": "30m",
                "H1": "1h", "H4": "4h", "D1": "1d",
            }
            api_interval = interval_map.get(timeframe_str, "15m")

            # For crypto symbols, use Binance-style API
            is_crypto = base_symbol.upper().startswith(('BTC', 'ETH', 'LTC', 'XRP', 'ADA', 'SOL', 'DOGE'))

            if is_crypto:
                # Binance klines
                pair = base_symbol.upper()
                if pair.endswith("USD"):
                    pair = pair + "T"  # BTCUSD → BTCUSDT
                url = f"https://api.binance.com/api/v3/klines?symbol={pair}&interval={api_interval}&limit={count}"
                resp = http_requests.get(url, timeout=5)
                if resp.status_code == 200:
                    data = resp.json()
                    for k in data:
                        candles.append({
                            "time": int(k[0]) // 1000,
                            "open": float(k[1]),
                            "high": float(k[2]),
                            "low": float(k[3]),
                            "close": float(k[4]),
                            "volume": int(float(k[5])),
                        })
                    print(f"[Chart] {symbol}: {len(candles)} bars from Binance ({timeframe_str})")

            if not candles and len(base_symbol) == 6 and base_symbol.isalpha():
                # Forex — try TwelveData free API
                from_sym = base_symbol[:3]
                to_sym = base_symbol[3:]
                td_interval_map = {
                    "M1": "1min", "M5": "5min", "M15": "15min", "M30": "30min",
                    "H1": "1h", "H4": "4h", "D1": "1day",
                }
                td_interval = td_interval_map.get(timeframe_str, "15min")
                # Use free forex API
                url = f"https://api.exchangerate.host/timeseries?base={from_sym}&symbols={to_sym}&start_date=2025-01-01"
                # Fallback: generate synthetic candles from current price
                bid, ask_p, digits = _get_live_price(symbol)
                if bid > 0:
                    import random as rand
                    now = int(time.time())
                    interval_secs = tf_minutes * 60
                    price = (bid + ask_p) / 2
                    spread = ask_p - bid if ask_p > bid else price * 0.0002
                    for i in range(count):
                        t = now - (count - i) * interval_secs
                        # Small random walk based on spread
                        noise = spread * rand.uniform(-3, 3)
                        o = price + noise * rand.uniform(0.5, 1.5)
                        h = o + abs(noise) * rand.uniform(0.5, 2)
                        l = o - abs(noise) * rand.uniform(0.5, 2)
                        c = o + noise * rand.uniform(-1, 1)
                        candles.append({
                            "time": t,
                            "open": round(o, digits),
                            "high": round(max(h, o, c), digits),
                            "low": round(min(l, o, c), digits),
                            "close": round(c, digits),
                            "volume": rand.randint(100, 10000),
                        })
                    price = c  # walk forward
                    print(f"[Chart] {symbol}: {len(candles)} synthetic bars from live price ({timeframe_str})")

            if not candles:
                # For metals/indices/oil — synthetic from live price
                bid, ask_p, digits = _get_live_price(symbol)
                if bid > 0:
                    import random as rand
                    now = int(time.time())
                    interval_secs = tf_minutes * 60
                    price = (bid + ask_p) / 2
                    spread = ask_p - bid if ask_p > bid else price * 0.001
                    for i in range(count):
                        t = now - (count - i) * interval_secs
                        noise = spread * rand.uniform(-3, 3)
                        o = price + noise * rand.uniform(0.5, 1.5)
                        h = o + abs(noise) * rand.uniform(0.5, 2)
                        l = o - abs(noise) * rand.uniform(0.5, 2)
                        c = o + noise * rand.uniform(-1, 1)
                        candles.append({
                            "time": t,
                            "open": round(o, digits),
                            "high": round(max(h, o, c), digits),
                            "low": round(min(l, o, c), digits),
                            "close": round(c, digits),
                            "volume": rand.randint(100, 10000),
                        })
                        price = c
                    print(f"[Chart] {symbol}: {len(candles)} synthetic bars ({timeframe_str})")

        except Exception as e:
            print(f"[Chart] Fallback chart generation failed for {symbol}: {e}")

    if candles:
        _chart_cache[cache_key] = {"data": candles, "_ts": time.time()}

    return jsonify(success=True, symbol=symbol, timeframe=timeframe_str, candles=candles, count=len(candles))


@app.route("/tick/<symbol>", methods=["GET"])
def get_tick(symbol):
    """Get latest bid/ask tick for a symbol"""
    try:
        # Check cache first (valid for 5 seconds)
        cached = _tick_cache.get(symbol)
        if cached and (time.time() - cached.get("_ts", 0)) < 5:
            return jsonify(success=True, **{k: v for k, v in cached.items() if k != "_ts"})

        bid, ask, digits = _get_live_price(symbol)

        spread = round((ask - bid) * (10 ** digits)) if (bid > 0 and ask > 0) else 0

        result = {
            "symbol": symbol,
            "bid": round(bid, digits),
            "ask": round(ask, digits),
            "digits": digits,
            "spread": spread,
        }

        if bid > 0 or ask > 0:
            _tick_cache[symbol] = {**result, "_ts": time.time()}

        return jsonify(success=True, **result)

    except Exception as e:
        print(f"Error fetching tick for {symbol}: {str(e)}")
        return jsonify(success=True, symbol=symbol, bid=0, ask=0, digits=5, spread=0)


def _create_trade_request(login, symbol, trade_type, volume, sl=0, tp=0, comment="", position=0):
    """
    Create MTRequest object trying multiple constructor patterns.
    MT5Manager SDK varies by version — some need manager arg, some don't.
    Returns (request_obj, error_string) tuple.
    """
    req = None

    # Approach 1: MTRequest(manager) — most common in Python MT5 Manager SDK
    try:
        req = MT5Manager.MTRequest(manager)
        print(f"  MTRequest(manager) succeeded")
    except Exception as e1:
        print(f"  MTRequest(manager) failed: {e1}")

    # Approach 2: manager.TradeRequestCreate() or similar factory
    if req is None:
        for factory in ["TradeRequestCreate", "RequestCreate", "DealerRequest"]:
            try:
                fn = getattr(manager, factory, None)
                if fn:
                    req = fn()
                    print(f"  {factory}() succeeded")
                    break
            except Exception as e2:
                print(f"  {factory}() failed: {e2}")

    # Approach 3: bare MTRequest()
    if req is None:
        try:
            req = MT5Manager.MTRequest()
            print(f"  MTRequest() succeeded")
        except Exception as e3:
            print(f"  MTRequest() failed: {e3}")

    if req is None:
        return None, "Could not create MTRequest object with any approach"

    # Set fields — try multiple attribute naming conventions
    try:
        req.Login = login
    except:
        pass
    try:
        req.Symbol = symbol
    except:
        pass

    # Type: 0=BUY, 1=SELL
    try:
        req.Type = trade_type
    except:
        pass

    # Volume in MT5 units (lots * 10000)
    try:
        req.Volume = volume
    except:
        pass

    # Price — get live market price (CRITICAL: price=0 may cause instant stop-out)
    # For BUY: use Ask price. For SELL: use Bid price.
    market_price = 0.0
    try:
        bid, ask, _digits = _get_live_price(symbol)
        if trade_type == 0:  # BUY → use Ask
            market_price = ask if ask > 0 else bid
        else:  # SELL → use Bid
            market_price = bid if bid > 0 else ask
        print(f"  Market price for {symbol}: bid={bid}, ask={ask}, using={market_price}")
    except Exception as pe:
        print(f"  Failed to get market price: {pe}")

    for price_attr in ["PriceOrder", "Price", "PriceOpen"]:
        try:
            setattr(req, price_attr, market_price)
        except:
            pass

    # Action — dealer execute
    for action_enum in [
        "TA_DEALER_POS_EXECUTE",
        "TA_DEALER_ORD_EXECUTE",
        "DEALER_POS_EXECUTE",
    ]:
        try:
            action_val = getattr(MT5Manager.MTRequest.EnTradeActions, action_enum, None)
            if action_val is not None:
                req.Action = action_val
                break
        except:
            pass

    # SL / TP
    if sl > 0:
        for sl_attr in ["SL", "PriceSL"]:
            try:
                setattr(req, sl_attr, float(sl))
            except:
                pass
    if tp > 0:
        for tp_attr in ["TP", "PriceTP"]:
            try:
                setattr(req, tp_attr, float(tp))
            except:
                pass

    # Comment
    try:
        req.Comment = comment
    except:
        pass

    # Position ticket (for closing)
    if position > 0:
        try:
            req.Position = position
        except:
            pass

    return req, None


@app.route("/debug/trade-methods", methods=["GET"])
def debug_trade_methods():
    """Debug: list all methods that could execute trades"""
    if not connect():
        return jsonify(error=MT5Manager.LastError()), 500

    methods = {}
    search_terms = ["order", "trade", "deal", "send", "execute", "transaction", "position"]
    for m in sorted(dir(manager)):
        if any(t in m.lower() for t in search_terms) and not m.startswith("_"):
            try:
                fn = getattr(manager, m)
                methods[m] = "callable" if callable(fn) else str(type(fn).__name__)
            except:
                methods[m] = "error"

    # Also check MTRequest enum values for Action
    action_enums = {}
    try:
        for attr in dir(MT5Manager.MTRequest.EnTradeActions):
            if not attr.startswith("_"):
                try:
                    action_enums[attr] = int(getattr(MT5Manager.MTRequest.EnTradeActions, attr))
                except:
                    action_enums[attr] = str(getattr(MT5Manager.MTRequest.EnTradeActions, attr))
    except Exception as e:
        action_enums["error"] = str(e)

    return jsonify(success=True, trade_methods=methods, action_enums=action_enums)


# ===== Terminal Login Configuration =====
@app.route("/terminal/configure", methods=["POST"])
def configure_terminal():
    """
    Configure the MT5 Terminal trading account credentials.
    POST body: { "login": 2230031, "password": "trading_password", "server": "PipPulseFx-Server" }
    The terminal must be logged in to execute trades.
    """
    global _terminal_initialized
    data = request.json or {}

    login = data.get("login")
    password = data.get("password")
    server = data.get("server", "")

    if not login or not password:
        return jsonify(success=False, error="login and password are required"), 400

    MT5_TERMINAL_CONFIG["login"] = int(login)
    MT5_TERMINAL_CONFIG["password"] = password
    if server:
        MT5_TERMINAL_CONFIG["server"] = server

    # Reset terminal state and try to connect
    _terminal_initialized = False

    if not MT5_TERMINAL_AVAILABLE:
        return jsonify(success=False, error="MetaTrader5 Python package not installed"), 400

    result = init_terminal(login=int(login), password=password, server=server)

    if result:
        info = mt5.account_info()
        return jsonify(
            success=True,
            message=f"Terminal logged in as {login}",
            account_info={
                "login": info.login if info else login,
                "balance": info.balance if info else 0,
                "server": info.server if info else server,
                "name": info.name if info else "",
            } if info else None
        )
    else:
        err = mt5.last_error() if MT5_TERMINAL_AVAILABLE else "N/A"
        return jsonify(success=False, error=f"Terminal login failed: {err}"), 400


