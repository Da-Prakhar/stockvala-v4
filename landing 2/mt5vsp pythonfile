                    print(f"  DealerSend result: {send_result} (type={type(send_result).__name__})")

                    if send_result is not None and send_result is not False and isinstance(send_result, int):
                        dealer_order_id = send_result
                        print(f"  ✅ DealerSend returned Order ID={dealer_order_id}. Checking if server accepted it...")
                        
