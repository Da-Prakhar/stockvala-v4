                    else:
                        price = market_price
                        print(f"  No terminal tick, using API price: {price}")

                    # Ensure volume respects symbol specification
                    min_vol = getattr(sym_info, "volume_min", 0.01) if sym_info else 0.01
                    max_vol = getattr(sym_info, "volume_max", 1000.0) if sym_info else 1000.0
                    step_vol = getattr(sym_info, "volume_step", 0.01) if sym_info else 0.01

                    if min_vol > 0 and volume_lots < min_vol:
                        print(f"  Volume {volume_lots} < min {min_vol} for {symbol}. Adjusting to {min_vol}")
                        volume_lots = min_vol
                    elif max_vol > 0 and volume_lots > max_vol:
                        print(f"  Volume {volume_lots} > max {max_vol} for {symbol}. Adjusting to {max_vol}")
                        volume_lots = max_vol

                    if step_vol > 0:
                        volume_lots = round(round(volume_lots / step_vol) * step_vol, 4)
                        if volume_lots <= 0:
                            volume_lots = min_vol

                    # Build the trade request
                    trade_request = {
                        "action": mt5.TRADE_ACTION_DEAL,
                        "symbol": symbol,
                        "volume": volume_lots,
                        "type": mt5.ORDER_TYPE_BUY if order_type_buy else mt5.ORDER_TYPE_SELL,
                        "price": price,
                        "deviation": 50,
                        "magic": login,
                        "comment": comment,
                        "type_time": mt5.ORDER_TIME_GTC,
                        "type_filling": mt5.ORDER_FILLING_IOC,
                    }

                    if sl > 0:
                        trade_request["sl"] = float(sl)
                    if tp > 0:
                        trade_request["tp"] = float(tp)

                    print(f"  Sending order: {trade_request}")
                    result = mt5.order_send(trade_request)

                    if result is None or (result and result.retcode != mt5.TRADE_RETCODE_DONE):
                        print(f"  order_send initial result: {result or mt5.last_error()}. Trying fallback filling modes...")
                        for fill_mode in [mt5.ORDER_FILLING_FOK, mt5.ORDER_FILLING_RETURN, mt5.ORDER_FILLING_IOC]:
                            trade_request["type_filling"] = fill_mode
                            result = mt5.order_send(trade_request)
                            if result and result.retcode == mt5.TRADE_RETCODE_DONE:
                                break

                    if result and result.retcode == mt5.TRADE_RETCODE_DONE:
                        print(f"  ✅ Trade executed! deal={result.deal}, order={result.order}, price={result.price}")
                        return jsonify(
                            success=True,
                            deal_id=result.deal,
                            order_id=result.order,
                            position_ticket=result.order,
                            login=login, symbol=symbol, action=action,
                            volume=result.volume, price=result.price,
                            sl=sl, tp=tp,
                            method="mt5_terminal_order_send",
                            message=f"Trade executed: {action.upper()} {result.volume} {symbol} @ {result.price}"
                        )
                    else:
                        retcode = result.retcode if result else "no_result"
                        ret_comment = result.comment if result else "N/A"
                        print(f"  Terminal order_send failed: retcode={retcode}, comment={ret_comment}")
                else:
                    print(f"  Symbol {symbol} not found in terminal")
            else:
                print(f"  MT5 Terminal not initialized or ensure_terminal failed")
        else:
            print(f"  MT5 Terminal package not available")

        # ── PRIORITY 3 (FALLBACK): DealAdd via Manager API ──
        # NOTE: DealAdd creates a deal record but NOT a real position.
        # Position is tracked in the CRM database instead.
        if not connect():
            return jsonify(error=MT5Manager.LastError()), 500

        print(f"  [P3-FALLBACK] Using DealAdd (creates deal record, position tracked in DB)")

        try:
            deal_obj = MT5Manager.MTDeal(manager)
            now_sec = int(time.time())

            for attr, val in [
                ("Login", login), ("Symbol", symbol), ("Action", trade_type),
                ("Volume", volume_units), ("Price", market_price),
                ("PricePosition", market_price), ("Entry", 0),
                ("Dealer", MT5_CONFIG["manager"]), ("Comment", comment),
                ("Time", now_sec), ("TimeMsc", int(now_sec * 1000)),
                ("MarketBid", bid), ("MarketAsk", ask),
                ("Digits", digits), ("ContractSize", 1.0),
                ("RateProfit", 1.0), ("RateMargin", 1.0),
                ("Reason", 0), ("Flags", 0),
            ]:
                try:
                    setattr(deal_obj, attr, val)
                except:
                    pass

            if sl > 0:
                try: deal_obj.PriceSL = float(sl)
                except: pass
            if tp > 0:
                try: deal_obj.PriceTP = float(tp)
                except: pass

            da_result = manager.DealAdd(deal_obj)
            if da_result:
                deal_ticket = getattr(deal_obj, "Deal", 0)
                print(f"  DealAdd OK, deal ticket = {deal_ticket}")
                return jsonify(
                    success=True,
                    deal_id=deal_ticket,
                    login=login, symbol=symbol,
                    action=action, volume=volume_lots,
                    price=market_price, sl=sl, tp=tp,
                    method="DealAdd_fallback",
                    message=f"Deal recorded (DB-tracked): {action.upper()} {volume_lots} {symbol} @ {market_price}"
                )
            else:
                err = MT5Manager.LastError()
                print(f"  DealAdd also failed: {err}")
                return jsonify(success=False, error=f"All trade execution methods failed. Last: {err}"), 400
        except Exception as da_e:
            print(f"  DealAdd exception: {da_e}")
            return jsonify(success=False, error=str(da_e)), 500

    except Exception as e:
        print(f"Error opening trade: {str(e)}")
        import traceback
        traceback.print_exc()
        return jsonify(success=False, error=str(e)), 500


@app.route("/trade/close", methods=["POST"])
def close_trade():
    """
    Close an open position by ticket.
    Uses MT5 Terminal API if available, falls back to Manager API DealAdd.
    """
    data = request.json

    try:
        login = int(data["login"])
        ticket = int(data["ticket"])
        comment = data.get("comment", "CRM Close")

        print(f"[TRADE] Closing position: login={login}, ticket={ticket}")

        # ── PRIORITY 0: MQL5 EA via file IPC ──
        if os.path.isdir(EA_COMMAND_DIR):
            print(f"  Trying close via MQL5 EA...")
            # For close, we write a special "close" command: CMD_ID,LOGIN,TICKET,close,0
            import uuid
            cmd_id = str(uuid.uuid4())[:8]
            cmd_line = f"{cmd_id},{login},{ticket},close,0,0,0,{comment}\n"
            os.makedirs(EA_COMMAND_DIR, exist_ok=True)
            with open(EA_COMMAND_FILE, "a") as f:
                f.write(cmd_line)
            print(f"  [EA-IPC] Close command: {cmd_line.strip()}")

            # Wait for result
            for _ in range(40):
                time.sleep(0.25)
                if os.path.exists(EA_RESULT_FILE):
                    try:
                        with open(EA_RESULT_FILE, "r") as f:
                            content = f.read()
                        for line in content.strip().split("\n"):
                            if line.startswith(cmd_id):
                                parts = line.split(",")
                                os.remove(EA_RESULT_FILE)
                                if len(parts) >= 2 and parts[1] == "SUCCESS":
                                    print(f"  ✅ Position {ticket} closed via EA")
                                    return jsonify(
                                        success=True,
                                        deal_id=int(parts[2]) if len(parts) > 2 else 0,
                                        login=login, ticket=ticket,
                                        method="mql5_ea_close",
                                        message=f"Position {ticket} closed via EA"
                                    )
                                else:
                                    print(f"  EA close failed: {parts}")
                                    break
                    except:
                        pass
            print(f"  EA close failed or not running, falling through...")

        # ── PRIMARY: MT5 Terminal API — detect market from position symbol ──
        # Thread-safe: acquire terminal lock for close operation
        _terminal_close_done = False
        if MT5_TERMINAL_AVAILABLE:
          with _terminal_lock:
            pos_symbol = None
            try:
                if _terminal_initialized:
                    _pos = mt5.positions_get(ticket=ticket)
                    if _pos and len(_pos) > 0:
                        pos_symbol = _pos[0].symbol
            except:
                pass
            if login_client_terminal(login):
                print(f"  Using MT5 Terminal API for close directly on client account {login}")

                # Find the position
                positions = mt5.positions_get(ticket=ticket)
                if not positions:
                    positions = mt5.positions_get(login=login)
                    if positions:
                        positions = [p for p in positions if p.ticket == ticket]

                if positions:
                    pos = positions[0]
                    symbol = pos.symbol
                    volume = pos.volume
                    pos_type = pos.type  # 0=BUY, 1=SELL
                    close_type = mt5.ORDER_TYPE_SELL if pos_type == 0 else mt5.ORDER_TYPE_BUY

                    tick = mt5.symbol_info_tick(symbol)
                    if tick:
                        price = tick.bid if pos_type == 0 else tick.ask
                    else:
                        bid, ask, _ = _get_live_price(symbol)
                        price = bid if pos_type == 0 else ask

                    close_request = {
                        "action": mt5.TRADE_ACTION_DEAL,
                        "symbol": symbol,
                        "volume": volume,
                        "type": close_type,
                        "position": ticket,
                        "price": price,
                        "deviation": 50,
                        "magic": login,
                        "comment": comment,
                        "type_time": mt5.ORDER_TIME_GTC,
                        "type_filling": mt5.ORDER_FILLING_IOC,
                    }

                    result = mt5.order_send(close_request)

                    if result is None:
                        for fill_mode in [mt5.ORDER_FILLING_FOK, mt5.ORDER_FILLING_RETURN]:
                            close_request["type_filling"] = fill_mode
                            result = mt5.order_send(close_request)
                            if result and result.retcode == mt5.TRADE_RETCODE_DONE:
                                break

                    if result and result.retcode == mt5.TRADE_RETCODE_DONE:
                        print(f"  ✅ Position {ticket} closed! deal={result.deal}")
                        _terminal_close_done = True
                        return jsonify(
                            success=True,
                            deal_id=result.deal,
                            login=login,
                            ticket=ticket,
                            method="mt5_terminal_order_send",
                            message=f"Position {ticket} closed @ {result.price}"
                        )
                    else:
                        retcode = result.retcode if result else "no_result"
                        ret_comment = result.comment if result else "N/A"
                        print(f"  Terminal close failed: retcode={retcode}, comment={ret_comment}")
                else:
                    print(f"  Position {ticket} not found in terminal")

        # ── FALLBACK: Manager API (DealerSend for close + DealAdd) ──
        if not connect():
            return jsonify(error=MT5Manager.LastError()), 500

        print(f"  Using Manager API for close")

        # Get position details from Manager API
        positions_data = manager.PositionGetByLogins([login])
        if not positions_data:
            return jsonify(success=False, error="No positions found for this account"), 404

        target_pos = None
        for pos in positions_data:
            if getattr(pos, "Position", 0) == ticket:
                target_pos = pos
                break

        if not target_pos:
            return jsonify(success=False, error=f"Position {ticket} not found"), 404

        symbol = getattr(target_pos, "Symbol", "")
        volume = getattr(target_pos, "Volume", 0)
        pos_action = getattr(target_pos, "Action", 0)
        close_type = 1 if pos_action == 0 else 0  # Opposite direction

        # Get live price for close
        bid, ask, digits = _get_live_price(symbol)
        close_price = bid if pos_action == 0 else ask  # Close BUY at bid, SELL at ask
        print(f"  Close price: bid={bid}, ask={ask}, using={close_price}")

        # Count positions before
        pos_before = len(positions_data)

        # Try DealerSend for close with correct prices
        try:
            manager.DealerStart()
        except:
            pass

        for action_val, action_name in [(2, "TA_INSTANT"), (3, "TA_MARKET")]:
            try:
                req = MT5Manager.MTRequest(manager)
                req.Login = login
                req.Symbol = symbol
                req.Type = close_type
                req.Volume = volume
                req.PriceOrder = close_price
                req.Action = action_val

                for attr, val in [("Deviation", 50), ("Comment", comment), ("TypeFill", 2), ("TypeTime", 0)]:
                    try: setattr(req, attr, val)
                    except: pass
                try: req.Position = ticket
                except: pass

                print(f"  DealerSend close(Action={action_val}/{action_name}, price={close_price})...")
                result = manager.DealerSend(req)
                print(f"  DealerSend close result: {result}")

                if result is not None and result is not False:
                    time.sleep(1.5)
                    # Check if position was closed
                    try:
                        pdata = manager.PositionGetByLogins([login])
                        pos_after = len(pdata) if pdata else 0
                        # Check if our specific ticket is gone
                        ticket_still_exists = any(getattr(p, "Position", 0) == ticket for p in (pdata or []))
                        if not ticket_still_exists:
                            deal_id = result if isinstance(result, int) else 0
                            print(f"  ✅ Position {ticket} CLOSED via DealerSend! deal={deal_id}")
                            try: manager.DealerStop()
                            except: pass
                            return jsonify(
                                success=True,
                                deal_id=deal_id,
                                login=login, ticket=ticket,
                                method=f"DealerSend_close_{action_name}",
                                message=f"Position {ticket} closed @ {close_price}"
                            )
                    except:
                        pass
            except Exception as e:
                print(f"  DealerSend close error: {e}")

        try: manager.DealerStop()
        except: pass

        # Last resort: DealAdd with close entry
        print(f"  DealerSend close didn't work, using DealAdd close fallback...")
        try:
            deal_obj = MT5Manager.MTDeal(manager)
            now_sec = int(time.time())
            for attr, val in [
                ("Login", login), ("Symbol", symbol), ("Action", close_type),
                ("Volume", volume), ("Price", close_price),
                ("PricePosition", getattr(target_pos, "PriceOpen", close_price)),
                ("Entry", 1),  # 1 = ENTRY_OUT (close)
                ("Dealer", MT5_CONFIG["manager"]), ("Comment", comment),
                ("Time", now_sec), ("TimeMsc", int(now_sec * 1000)),
                ("MarketBid", bid), ("MarketAsk", ask),
                ("Digits", digits), ("ContractSize", 1.0),
                ("RateProfit", 1.0), ("RateMargin", 1.0),
                ("Position", ticket), ("Reason", 0),
            ]:
                try: setattr(deal_obj, attr, val)
                except: pass

            da_result = manager.DealAdd(deal_obj)
            if da_result:
                deal_ticket = getattr(deal_obj, "Deal", 0)
                print(f"  DealAdd close OK, deal={deal_ticket}")
                return jsonify(success=True, deal_id=deal_ticket, login=login, ticket=ticket,
                               method="DealAdd_close_fallback",
                               message=f"Position {ticket} close recorded (DB-tracked)")
            else:
                err = MT5Manager.LastError()
                print(f"  Close failed: {err}")
                return jsonify(success=False, error=f"Close failed: {err}"), 400
        except Exception as da_e:
            print(f"  DealAdd close exception: {da_e}")
            return jsonify(success=False, error=str(da_e)), 500

    except Exception as e:
        print(f"Error closing trade: {str(e)}")
        import traceback
        traceback.print_exc()
        return jsonify(success=False, error=str(e)), 500


