def _get_live_price(symbol):
    """Get live bid/ask for any symbol using public APIs"""
    digits = SYMBOL_DIGITS.get(symbol, 5)

    # Strip broker suffixes like .#, .raw, .pro for API lookups
    base_symbol = symbol.split(".")[0] if "." in symbol else symbol

    # For MCX/NSE symbols, resolve to the actual futures contract name first
    market = _detect_market(symbol)
    resolved_mcx = None
    if market == "mcx":
        resolved_mcx = _resolve_mcx_symbol(base_symbol)
        digits = SYMBOL_DIGITS.get(base_symbol, 0)  # MCX symbols typically have 0 digits for gold

    # 1. Try MT5 SDK first (TickLast) — with multiple symbol name variants
    try:
        if connect():
            # Build variant list: resolved MCX name, original, base, suffixed
            sym_variants = []
            if resolved_mcx:
                sym_variants.append(resolved_mcx)
            sym_variants.extend([symbol, base_symbol, symbol + ".#", base_symbol + ".#"])
            sym_variants = list(dict.fromkeys(sym_variants))  # deduplicate
            for sym_try in sym_variants:
                try:
                    tick = manager.TickLast(sym_try)
                    if tick:
                        bid = getattr(tick, "Bid", 0.0)
                        ask = getattr(tick, "Ask", 0.0)
                        if bid > 0 and ask > 0:
                            return bid, ask, digits
                except:
                    pass
    except:
        pass

    # 2. Try MT5 Terminal ONLY if already on the right market (no switching for tick data!)
    # Terminal switching is expensive and causes scalability issues.
    # Manager API TickLast above should handle ALL symbols already.
    if MT5_TERMINAL_AVAILABLE and _terminal_initialized:
        expected_market = market
        if _current_terminal_market == expected_market:
            try:
                sym_list = [symbol, base_symbol]
                if resolved_mcx:
                    sym_list.insert(0, resolved_mcx)
                for sym_try in sym_list:
                    sym_info = mt5.symbol_info(sym_try)
                    if sym_info and not sym_info.visible:
                        mt5.symbol_select(sym_try, True)
                        time.sleep(0.1)
                    tick = mt5.symbol_info_tick(sym_try)
                    if tick and tick.bid > 0:
                        return tick.bid, tick.ask, digits
            except:
                pass

    # 3. Crypto → Binance (use base symbol without suffix)
    if base_symbol in BINANCE_MAP or symbol in BINANCE_MAP:
        lookup = symbol if symbol in BINANCE_MAP else base_symbol
        bid, ask = _fetch_price_binance(lookup)
        if bid > 0:
            return bid, ask, digits

    # 4. Metals → metals API
    if base_symbol.startswith("XA") or base_symbol.startswith("XP"):
        bid, ask = _fetch_price_metals(base_symbol)
        if bid > 0:
            return bid, ask, digits

    # 5. Forex pairs (6-char base symbol) → forex API
    if len(base_symbol) == 6 and base_symbol.isalpha():
        bid, ask = _fetch_price_forex(base_symbol)
        if bid > 0:
            return bid, ask, digits

    return 0, 0, digits


