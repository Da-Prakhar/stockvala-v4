@app.route("/positions/<int:login>", methods=["GET"])
def get_positions_by_login(login):
    if not connect():
        return jsonify(error=MT5Manager.LastError()), 500

    try:
        # 1. Verify account exists
        user = manager.UserRequest(login)
        if not user:
            if reconnect():
                user = manager.UserRequest(login)
            if not user:
                return jsonify(success=False, error="Account not found"), 404

        # 2. Try multiple methods to get positions
        positions_data = None
        method_used = "none"

        # Approach 1: PositionGetByLogins([login])
        try:
            positions_data = manager.PositionGetByLogins([login])
            if positions_data is not None and positions_data is not False:
                method_used = "PositionGetByLogins"
                print(f"[Positions] PositionGetByLogins({login}): got {len(positions_data) if positions_data else 0} positions")
        except Exception as e1:
            print(f"[Positions] PositionGetByLogins failed: {e1}")

        # Approach 2: PositionGet(login) — positional arg
        if positions_data is None or positions_data is False:
            try:
                positions_data = manager.PositionGet(login)
                if positions_data is not None and positions_data is not False:
                    method_used = "PositionGet(login)"
                    print(f"[Positions] PositionGet({login}): got {len(positions_data) if positions_data else 0} positions")
            except Exception as e2:
                print(f"[Positions] PositionGet(login) failed: {e2}")

        # Approach 3: PositionGet(login=login) — keyword arg
        if positions_data is None or positions_data is False:
            try:
                positions_data = manager.PositionGet(login=login)
                if positions_data is not None and positions_data is not False:
                    method_used = "PositionGet(login=login)"
                    print(f"[Positions] PositionGet(login={login}): got {len(positions_data) if positions_data else 0} positions")
            except Exception as e3:
                print(f"[Positions] PositionGet(login=) failed: {e3}")

        # Approach 4: PositionRequest(login)
        if positions_data is None or positions_data is False:
            for fn_name in ["PositionRequest", "PositionRequestByLogins", "PositionGetByLogin"]:
                try:
                    fn = getattr(manager, fn_name, None)
                    if fn:
                        if "Logins" in fn_name:
                            positions_data = fn([login])
                        else:
                            positions_data = fn(login)
                        if positions_data is not None and positions_data is not False:
                            method_used = fn_name
                            print(f"[Positions] {fn_name}: got {len(positions_data) if positions_data else 0} positions")
                            break
                except Exception as e4:
                    print(f"[Positions] {fn_name} failed: {e4}")

        if not positions_data:
            print(f"[Positions] No positions found for login {login} (method: {method_used})")
            return jsonify(success=True, login=login, total_positions=0, positions=[], method=method_used), 200

        # 3. Format positions for JSON
        formatted_positions = []
        for i, pos in enumerate(positions_data):
            # Debug: dump first position's attributes
            if i == 0:
                pos_attrs = {}
                for attr in dir(pos):
                    if not attr.startswith("_"):
                        try:
                            val = getattr(pos, attr)
                            if not callable(val):
                                pos_attrs[attr] = str(val)
                        except:
                            pass
                print(f"[Positions] First position attributes: {pos_attrs}")

            # Volume: MT5 stores in units (10000 = 1 lot). VolumeExt is 100M = 1 lot.
            vol_raw = getattr(pos, "Volume", 0)
            vol_ext = getattr(pos, "VolumeExt", 0)
            if vol_raw and vol_raw > 0:
                vol_lots = vol_raw / 10000
            elif vol_ext and vol_ext > 0:
                vol_lots = vol_ext / 100000000
            else:
                vol_lots = 0

            formatted_positions.append({
                "ticket": getattr(pos, "Position", getattr(pos, "Ticket", 0)),
                "symbol": getattr(pos, "Symbol", ""),
                "type": "BUY" if getattr(pos, "Action", 0) == 0 else "SELL",
                "volume": vol_lots,
                "price_open": getattr(pos, "PriceOpen", 0.0),
                "price_current": getattr(pos, "PriceCurrent", 0.0),
                "profit": getattr(pos, "Profit", 0.0),
                "sl": getattr(pos, "PriceSL", 0.0),
                "tp": getattr(pos, "PriceTP", 0.0),
                "swap": getattr(pos, "Storage", 0.0),
                "time_create": getattr(pos, "TimeCreate", 0),
            })

        print(f"[Positions] Returning {len(formatted_positions)} positions for login {login} via {method_used}")

        return jsonify(
            success=True,
            login=login,
            account_name=f"{user.FirstName} {user.LastName}",
            total_positions=len(formatted_positions),
            positions=formatted_positions,
            method=method_used
        )

    except Exception as e:
        print(f"[Positions] Exception for login {login}: {str(e)}")
        return jsonify(success=False, error=str(e)), 500


