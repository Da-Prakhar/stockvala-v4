@app.route("/deals/<int:login>", methods=["GET"])
def get_deals(login):
    """Get deal history for a specific account"""
    if not connect():
        return jsonify(error=MT5Manager.LastError()), 500

    try:
        # Get time range from query params (default: last 30 days)
        from_ts = request.args.get("from", None)
        to_ts = request.args.get("to", None)

        now = int(time.time())
        if from_ts:
            from_time = int(from_ts)
        else:
            from_time = now - (30 * 24 * 60 * 60)  # 30 days ago
        if to_ts:
            to_time = int(to_ts)
        else:
            to_time = now

        print(f"Fetching deals for login={login}, from={from_time}, to={to_time}")

        deals_data = None
        # Approach 1: DealRequestByLogins (login list, from, to)
        try:
            deals_data = manager.DealRequestByLogins([login], from_time, to_time)
            print(f"DealRequestByLogins succeeded: {type(deals_data)}")
        except Exception as e1:
            print(f"DealRequestByLogins failed: {e1}")

        # Approach 2: DealRequest (from, to) — returns all deals, filter by login
        if deals_data is None or deals_data is False:
            try:
                all_deals = manager.DealRequest(from_time, to_time)
                if all_deals:
                    deals_data = [d for d in all_deals if getattr(d, "Login", 0) == login]
                    print(f"DealRequest filtered: {len(deals_data)} deals for login {login}")
            except Exception as e2:
                print(f"DealRequest failed: {e2}")

        # Approach 3: HistoryRequestByLogins
        if deals_data is None or deals_data is False:
            try:
                deals_data = manager.HistoryRequestByLogins([login], from_time, to_time)
                print(f"HistoryRequestByLogins succeeded: {type(deals_data)}")
            except Exception as e3:
                print(f"HistoryRequestByLogins failed: {e3}")

        if deals_data is False or deals_data is None:
            disconnect()
            return jsonify(success=True, login=login, total=0, deals=[])

        deals = []
        # Action enum: 0=BUY, 1=SELL, 2=BALANCE, 3=CREDIT, 4=CHARGE, etc.
        ACTION_MAP = {0: "buy", 1: "sell", 2: "balance", 3: "credit", 4: "charge", 5: "correction"}
        for deal in deals_data:
            action_val = getattr(deal, "Action", 0)
            deals.append({
                "deal": getattr(deal, "Deal", 0),
                "ticket": getattr(deal, "Deal", 0),
                "order": getattr(deal, "Order", 0),
                "login": getattr(deal, "Login", login),
                "symbol": getattr(deal, "Symbol", ""),
                "action": action_val,
                "type_str": ACTION_MAP.get(action_val, str(action_val)),
                "entry": getattr(deal, "Entry", 0),
                "volume": getattr(deal, "Volume", 0) / 10000,
                "price": getattr(deal, "Price", 0),
                "profit": getattr(deal, "Profit", 0),
                "commission": getattr(deal, "Commission", 0),
                "swap": getattr(deal, "Storage", 0),
                "comment": getattr(deal, "Comment", ""),
                "time_create": getattr(deal, "Time", 0),
            })

        disconnect()
        return jsonify(success=True, login=login, total=len(deals), deals=deals)
    except Exception as e:
        disconnect()
        print(f"Error fetching deals: {str(e)}")
        return jsonify(success=False, error=str(e)), 500


