@app.route("/trade/open", methods=["POST"])
def open_trade():
    """
    Open a trade (market order) on behalf of a client.

    Execution priority:
    1. MQL5 EA via file IPC (creates REAL positions — needs EA running in MT5 Terminal)
    2. DealerSend via Manager API (with correct prices + multiple Action enums)
    3. MT5 Terminal API (order_send) — if terminal is running
    4. DealAdd fallback (creates deal record, position tracked in DB)
    """
    data = request.json

    try:
        login = int(data["login"])
        raw_symbol = data["symbol"]
        symbol = _normalize_symbol(raw_symbol)  # Add .# suffix if needed
        action = data.get("action", "buy").lower()
        volume_lots = float(data.get("volume", 0.01))
        sl = float(data.get("sl", 0))
        tp = float(data.get("tp", 0))
        comment = data.get("comment", "CRM Trade")

        order_type_buy = (action == "buy")
        trade_type = 0 if order_type_buy else 1  # 0=BUY, 1=SELL

        print(f"\n{'='*60}")
        if raw_symbol != symbol:
            print(f"[TRADE] Symbol normalized: {raw_symbol} → {symbol}")
        print(f"[TRADE] Opening: login={login}, {action} {volume_lots} {symbol}, SL={sl}, TP={tp}")
        print(f"{'='*60}")

        # ── Get live price first (needed by all methods) ──
        bid, ask, digits = _get_live_price(symbol)
        market_price = ask if order_type_buy else bid
        print(f"  Price: bid={bid}, ask={ask}, using={market_price}")

        if market_price <= 0:
            # Try terminal tick as fallback
            if MT5_TERMINAL_AVAILABLE and _terminal_initialized:
                try:
                    tick = mt5.symbol_info_tick(symbol)
                    if tick and tick.bid > 0:
                        bid, ask = tick.bid, tick.ask
                        market_price = ask if order_type_buy else bid
                        print(f"  Terminal tick fallback: bid={bid}, ask={ask}, using={market_price}")
                except:
                    pass
            if market_price <= 0:
                return jsonify(success=False, error=f"Cannot get price for {symbol} — bid={bid}, ask={ask}"), 400

        volume_units = int(volume_lots * 10000)

        # ── PRIORITY 0: MQL5 EA via file IPC (creates REAL positions) ──
        if os.path.isdir(EA_COMMAND_DIR):
            print(f"  [P0] Trying MQL5 EA via file IPC...")
            ea_success, ea_result = _send_trade_via_ea(login, symbol, action, volume_lots, sl, tp, comment)
            if ea_success:
                print(f"  ✅ EA trade executed! {ea_result}")
                return jsonify(
                    success=True,
                    deal_id=ea_result.get("deal_id", 0),
                    order_id=ea_result.get("order_id", 0),
                    login=login, symbol=symbol, action=action,
                    volume=ea_result.get("volume", volume_lots),
                    price=ea_result.get("price", 0),
                    sl=sl, tp=tp,
                    method="mql5_ea_order_send",
