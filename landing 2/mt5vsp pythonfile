# ===== File IPC for MQL5 EA trade execution =====
# ===== Symbol suffix mapping =====
# The broker uses ".#" suffix on all symbols (EURUSD.#, BTCUSD.#, XAUUSD.#)
# CRM frontend sends without suffix — we need to add it for MT5
BROKER_SYMBOL_SUFFIX = ".#"

# Cache of known MT5 symbols (populated on first use)
_mt5_symbols_cache = set()
_mt5_symbols_cache_time = 0

# ===== MCX SYMBOL RESOLVER =====
# MCX/NSE symbols are futures contracts with expiry dates: GOLD → GOLDJUN26, SILVER → SILVERJUL26
# The active contract changes every expiry. This resolver finds the current one dynamically.
_mcx_symbol_cache = {}   # {"GOLD": "GOLDJUN26", "SILVER": "SILVERJUL26", ...}
_mcx_symbol_cache_time = 0
MCX_CACHE_TTL = 300  # Refresh every 5 minutes

def _resolve_mcx_symbol(base_name):
    """
    Resolve a base MCX symbol (GOLD, SILVER, CRUDEOIL) to the actual MT5 symbol
    with expiry date (GOLDJUN26, SILVERJUL26, CRUDEOILMAY26).

    PRIORITY:
    1. Cache (5 min TTL)
    2. Manager API TickLast — works for ALL symbols, no terminal switching needed
    3. MT5 Terminal symbols_get — only if terminal is on MCX account already
    """
    global _mcx_symbol_cache, _mcx_symbol_cache_time

    base_name = base_name.upper().replace(".#", "").replace(".", "")

    # Check cache first
    now = time.time()
    if base_name in _mcx_symbol_cache and (now - _mcx_symbol_cache_time) < MCX_CACHE_TTL:
        return _mcx_symbol_cache[base_name]

    # ── PRIORITY 1: Manager API TickLast — no terminal switching needed ──
    # The Manager API sees ALL symbols across all groups
    # Try TWO naming patterns:
    #   MCX style:  {NAME}{MONTH}{YEAR}  → GOLDJUN26, SILVERJUL26, CRUDEOILMAY26
    #   NSE style:  {NAME}{MONTH}        → BANKNIFTYMAY, TATASTEELMAY, NIFTYMAY
    if connect():
        import datetime
        now_dt = datetime.datetime.now()
        months_short = ["JAN", "FEB", "MAR", "APR", "MAY", "JUN", "JUL", "AUG", "SEP", "OCT", "NOV", "DEC"]
        for offset in range(0, 4):
            m = (now_dt.month - 1 + offset) % 12
            y = now_dt.year + ((now_dt.month - 1 + offset) // 12)
            yr = str(y)[-2:]  # Last 2 digits of year
            month_name = months_short[m]
            # Try both patterns: with year (MCX) and without year (NSE)
            candidates_to_try = [
                f"{base_name}{month_name}{yr}",   # GOLDJUN26, BANKNIFTYMAY26
                f"{base_name}{month_name}",        # BANKNIFTYMAY, TATASTEELMAY
                f"{base_name}{yr}{month_name}",    # BANKNIFTY26MAY (alternate format)
            ]
            for candidate in candidates_to_try:
                try:
                    tick = manager.TickLast(candidate)
                    if tick:
                        bid = getattr(tick, "Bid", 0.0)
                        _mcx_symbol_cache[base_name] = candidate
                        _mcx_symbol_cache_time = now
                        if bid > 0:
                            print(f"[MCX Resolve] {base_name} → {candidate} (via TickLast, bid={bid})")
                        else:
                            print(f"[MCX Resolve] {base_name} → {candidate} (via TickLast, market may be closed)")
                        return candidate
                except:
                    pass

    # ── PRIORITY 2: Terminal symbols_get — only if already on MCX ──
    # Don't switch terminal just for resolution; that causes the scalability problem
    if MT5_TERMINAL_AVAILABLE and _terminal_initialized and _current_terminal_market == "mcx":
        try:
            matches = mt5.symbols_get(base_name + "*")
            if matches and len(matches) > 0:
                candidates = []
                for s in matches:
                    name = s.name
                    if base_name == "GOLD" and "GOLDM" in name:
                        continue
                    if base_name == "SILVER" and "SILVERM" in name:
                        continue
                    candidates.append(name)
                if candidates:
                    candidates.sort()
                    resolved = candidates[0]
                    _mcx_symbol_cache[base_name] = resolved
                    _mcx_symbol_cache_time = now
                    print(f"[MCX Resolve] {base_name} → {resolved} (from terminal, {len(candidates)} candidates)")
                    return resolved
        except Exception as e:
            print(f"[MCX Resolve] symbols_get failed for {base_name}: {e}")

    # Last resort: return as-is
    print(f"[MCX Resolve] Could not resolve {base_name}, using as-is")
    return base_name


def _normalize_symbol(symbol):
    """
    Ensure symbol has the correct format for MT5.
    Forex/Crypto/Comex symbols get '.#' suffix (EURUSD → EURUSD.#)
    MCX/NSE symbols get resolved to their futures contract name (GOLD → GOLDJUN26)
    """
    if not symbol:
        return symbol

    # Already has the suffix
    if symbol.endswith(BROKER_SYMBOL_SUFFIX):
        return symbol

    # Already has some other suffix (e.g. .raw, .pro)
    if "." in symbol:
        return symbol

    # MCX/NSE symbols need dynamic resolution to current futures contract
    market = _detect_market(symbol)
    if market == "mcx":
        return _resolve_mcx_symbol(symbol)

    # Try to verify against known MT5 symbols
    global _mt5_symbols_cache, _mt5_symbols_cache_time
    now = time.time()

    # Refresh symbol cache every 5 minutes
    if not _mt5_symbols_cache or (now - _mt5_symbols_cache_time) > 300:
        try:
            if connect():
                syms = manager.SymbolNext(0)  # Try to get symbols
                if syms:
                    for s in (syms if isinstance(syms, (list, tuple)) else [syms]):
                        name = getattr(s, "Symbol", getattr(s, "Name", ""))
                        if name:
                            _mt5_symbols_cache.add(name)
                    _mt5_symbols_cache_time = now
        except:
            pass

    # If we have a cache, check if suffixed version exists
    suffixed = symbol + BROKER_SYMBOL_SUFFIX
    if _mt5_symbols_cache:
        if suffixed in _mt5_symbols_cache:
            return suffixed
        if symbol in _mt5_symbols_cache:
            return symbol
        # Default: add suffix (broker convention)
        return suffixed
    else:
        # No cache available — just add suffix for forex/crypto (broker convention)
        return suffixed


EA_COMMAND_DIR = "C:\\StockValaCRM"
EA_COMMAND_FILE = os.path.join(EA_COMMAND_DIR, "trade_commands.csv")
EA_RESULT_FILE = os.path.join(EA_COMMAND_DIR, "trade_results.csv")

def _send_trade_via_ea(login, symbol, action, volume, sl=0, tp=0, comment="CRM_Trade"):
    """
    Write a trade command to the shared file for the MQL5 EA to pick up.
    Returns (success, result_dict) after waiting for EA response.
    """
    import uuid
    cmd_id = str(uuid.uuid4())[:8]

    # Ensure directory exists
    os.makedirs(EA_COMMAND_DIR, exist_ok=True)

    # Write command
    cmd_line = f"{cmd_id},{login},{symbol},{action},{volume},{sl},{tp},{comment}\n"
    with open(EA_COMMAND_FILE, "a") as f:
        f.write(cmd_line)

    print(f"[EA-IPC] Wrote command: {cmd_line.strip()}")

    # Wait for result (poll for up to 10 seconds)
    for _ in range(40):  # 40 x 0.25s = 10 seconds
        time.sleep(0.25)
        if os.path.exists(EA_RESULT_FILE):
            try:
                with open(EA_RESULT_FILE, "r") as f:
                    content = f.read()
                # Look for our command ID in results
                for line in content.strip().split("\n"):
                    if line.startswith(cmd_id):
                        parts = line.split(",")
                        os.remove(EA_RESULT_FILE)
                        if len(parts) >= 4 and parts[1] == "SUCCESS":
                            return True, {
                                "deal_id": int(parts[2]) if parts[2] != "0" else 0,
                                "order_id": int(parts[3]) if parts[3] != "0" else 0,
                                "price": float(parts[4]) if len(parts) > 4 else 0,
                                "volume": float(parts[5]) if len(parts) > 5 else volume,
                                "method": "mql5_ea_order_send",
                            }
                        else:
                            return False, {
                                "error": parts[2] if len(parts) > 2 else "Unknown error",
                                "retcode": parts[1] if len(parts) > 1 else "FAILED",
                            }
            except Exception as e:
                print(f"[EA-IPC] Error reading result: {e}")

    return False, {"error": "EA did not respond within 10 seconds — is the EA running in MT5 Terminal?"}


